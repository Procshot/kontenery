# Lokalnie pozostaw "/". Dla statycznego hostingu w podkatalogu użyj np. "/kontenery/".
VITE_BASE_PATH=/

# Opcjonalny czas ważności lokalnego cache synchronizatora w milisekundach.
EKOSYSTEM_CACHE_TTL_MS=21600000

# Opcjonalny endpoint wyszukiwania adresów. Pozwala zmienić dostawcę bez przebudowy kodu.
VITE_GEOCODING_URL=https://nominatim.openstreetmap.org/search
